# =============================================================================
# Meeting Intelligence Agent — .gitignore
# =============================================================================
# Files and folders listed here are NEVER pushed to GitHub.
# The most important one is .env — it contains all your secret API keys.
# =============================================================================


# -----------------------------------------------------------------------------
# SECRET FILES — never push these, ever
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
*.env

# Google service account credentials JSON (contains private key)
credentials/
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig*.json


# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------

# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest cache
.pytest_cache/
.cache/

# Coverage reports
htmlcov/
.coverage
coverage.xml

# Ruff / linter cache
.ruff_cache/

# MyPy type checker
.mypy_cache/


# -----------------------------------------------------------------------------
# UPLOADED AUDIO FILES — never push actual meeting recordings
# -----------------------------------------------------------------------------
uploads/
/tmp/
*.mp3
*.wav
*.m4a
*.ogg
*.flac
*.webm


# -----------------------------------------------------------------------------
# NODE / NEXT.JS (frontend)
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# Linux
*~


# -----------------------------------------------------------------------------
# IDE / EDITOR
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace


# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/


# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.docker/